import json
import os
import sys
import requests

BASE_URL = "https://api.fireworks.ai/inference/v1"
MODEL = "accounts/fireworks/models/minimax-m3"

STYLE_DEFINITIONS = {
    "formal": "Professional, objective, factual tone",
    "sarcastic": "Dry, ironic, lightly mocking",
    "humorous_tech": "Funny, with technology or programming references",
    "humorous_non_tech": "Funny, everyday humour with no technical jargon",
}

STYLE_LENGTH = {
    "formal": "3-4 sentences",
    "sarcastic": "3-4 sentences",
    "humorous_tech": "3-4 sentences",
    "humorous_non_tech": "3-4 sentences",
}

STYLE_TONE_MARKERS = {
    "formal": "Use formal vocabulary, complete sentences, and a neutral professional tone.",
    "sarcastic": "Use irony, understatement, and a dry critical tone. The sarcasm should be subtle, not obvious.",
    "humorous_tech": "Use playful tech metaphors, programming references, and a witty tone.",
    "humorous_non_tech": "Use relatable everyday humor, observational comedy, and a casual tone.",
}

STYLE_EXTRA_GUIDANCE = {
    "formal": "Be precise and descriptive, but do not pad with unnecessary detail.",
    "sarcastic": "Land a sharp, dry observation that could only apply to THIS scene.",
    "humorous_tech": "Tie tech/programming metaphors directly to real visual details from the description.",
    "humorous_non_tech": "Land a clear, relatable joke. No technical references at all.",
}

STYLE_EXAMPLES = {
    "formal": "A woman in a beige shirt types at a white desk in a modern office, surrounded by glass partitions and warm lighting.",
    "sarcastic": "Another riveting day in corporate paradise: a woman types furiously while her potted plant judges her silently.",
    "humorous_tech": "She's committing code faster than her RAM can handle, and those tangled cables are begging for a git reset.",
    "humorous_non_tech": "She came for the salary but stayed for the office plants that no one waters. Truly living the dream.",
}

INPUT_PATH = "/input/tasks.json"
OUTPUT_PATH = "/output/results.json"


def get_api_key():
    key = os.environ.get("FIREWORKS_API_KEY")
    if not key:
        print("ERROR: FIREWORKS_API_KEY environment variable not set", file=sys.stderr)
        sys.exit(1)
    return key


def normalize_key(key):
    key_lower = key.lower().strip()
    key_mappings = {
        'sarcastic': 'sarcastic',
        'sarcasm': 'sarcastic',
        'sarcastik': 'sarcastic',
        'sarcastc': 'sarcastic',
        'humorous_tech': 'humorous_tech',
        'tech_humour': 'humorous_tech',
        'tech_humor': 'humorous_tech',
        'humorous_non_tech': 'humorous_non_tech',
        'nontech_humour': 'humorous_non_tech',
        'nontech_humor': 'humorous_non_tech',
        'formal': 'formal',
        'formel': 'formal',
    }
    if key_lower in key_mappings:
        return key_mappings[key_lower]
    if 'sarcas' in key_lower:
        return 'sarcastic'
    return key_lower


def get_video_description(video_url, api_key):
    resp = requests.post(
        f"{BASE_URL}/chat/completions",
        headers={"Authorization": f"Bearer {api_key}"},
        json={
            "model": MODEL,
            "messages": [
                {
                    "role": "user",
                    "content": [
                        {
                            "type": "text",
                            "text": (
                                "Describe this video factually and specifically in exactly 5-7 sentences. "
                                "You MUST cover these elements in order, and be as concrete as possible:\n\n"
                                "1. SETTING: Where does this take place? What is the environment and time of day? "
                                "Describe the background, lighting, and any notable visual features.\n\n"
                                "2. SUBJECTS: Who or what is in the scene? Describe people (age range, hair color, "
                                "clothing colors/styles, accessories), animals (type, color, size, behavior), or "
                                "objects (size, color, material, position).\n\n"
                                "3. ACTION: What is happening? Describe the sequence of movements or events in the "
                                "order they occur. Be specific about durations (e.g., 'slowly walks', 'quickly types').\n\n"
                                "4. VISUAL DETAILS: Any text, signs, logos, or labels visible. Colors, textures, "
                                "patterns. Camera movement (pan, zoom, static).\n\n"
                                "5. MOOD: What is the overall atmosphere or feeling? Professional, relaxed, tense, "
                                "playful, serene?\n\n"
                                "CRITICAL: Be precise and literal. Do not speculate. Include every concrete detail "
                                "a viewer would need to write an accurate caption without watching the video.\n"
                                "Focus on what is VISIBLE, not what you assume is happening."
                            ),
                        },
                        {"type": "video_url", "video_url": {"url": video_url}},
                    ],
                }
            ],
            "max_tokens": 8000,
            "temperature": 0.1,
        },
        timeout=60,
    )
    resp.raise_for_status()
    result = resp.json()
    finish_reason = result["choices"][0]["finish_reason"]
    if finish_reason == "length":
        print(f"WARNING: description cut off for {video_url}", file=sys.stderr)
    return result["choices"][0]["message"]["content"]


def _map_parsed_to_styles(parsed, styles):
    result = {}
    for style in styles:
        if style in parsed:
            result[style] = parsed[style]
            continue
        found = False
        for key, value in parsed.items():
            if normalize_key(key) == style:
                result[style] = value
                found = True
                break
        if not found:
            result[style] = ""
    return result


def _validate_caption(text, style):
    if not text or len(text.strip()) < 15:
        return False
    text_lower = text.lower()
    banned = ["oh look", "ah yes", "behold", "truly groundbreaking", "the pinnacle of"]
    if any(phrase in text_lower for phrase in banned):
        return False
    if style == "formal" and text.count("!") > 1:
        return False
    return True


def _fallback_caption(style, description):
    words = description.split()[:20]
    key_detail = " ".join(words) if words else description[:200]
    
    templates = {
        "formal": f"This video shows {key_detail.lower()}, with additional details visible in the scene.",
        "sarcastic": f"The scene begins with {key_detail.lower()}, which is exactly as thrilling as it sounds.",
        "humorous_tech": f"System feedback: {key_detail.lower()} (please insert the rest of the caption here).",
        "humorous_non_tech": f"So basically, this is what happens when {key_detail.lower()} and you're just here for the ride.",
    }
    return templates.get(style, description[:200])


def get_styled_captions(description, styles, api_key, max_retries=2):
    style_list = ", ".join(styles)
    keys_example = ", ".join(f'"{s}": "..."' for s in styles)

    style_specs = "\n".join(
        f"- {s} ({STYLE_LENGTH[s]}): {STYLE_DEFINITIONS[s]}\n"
        f"  Tone: {STYLE_TONE_MARKERS[s]}\n"
        f"  Guidance: {STYLE_EXTRA_GUIDANCE[s]}\n"
        f"  Example: {STYLE_EXAMPLES[s]}"
        for s in styles
    )

    prompt = f"""Here is a factual description of a video:

"{description}"

Write a caption for this video in EACH of the following styles:

{style_specs}

IMPORTANT GUIDELINES:
1. Every caption MUST reference at least ONE specific, concrete detail from the description (color, object, action, setting feature).
2. Do NOT invent details not in the description. The humor comes from HOW you say it, not what you make up.
3. Use the tone markers to guide your writing style.
4. Vary sentence structure across all four captions.
5. Avoid these cliches: "Oh look", "Ah yes", "Behold", "Truly groundbreaking", "the pinnacle of".

PUNCTUATION: Use commas, periods, or parentheses. NO em dashes (—) or double hyphens (--).

CRITICAL: Respond with ONLY a valid JSON object using these EXACT keys:
{{{keys_example}}}
"""

    result = {s: "" for s in styles}

    for attempt in range(max_retries + 1):
        try:
            resp = requests.post(
                f"{BASE_URL}/chat/completions",
                headers={"Authorization": f"Bearer {api_key}"},
                json={
                    "model": MODEL,
                    "messages": [{"role": "user", "content": prompt}],
                    "max_tokens": 8000,
                    "temperature": 0.8,
                },
                timeout=60,
            )
            resp.raise_for_status()
            content = resp.json()["choices"][0]["message"]["content"]

            content = content.strip()
            if content.startswith("```"):
                content = content.split("```")[1]
                if content.startswith("json"):
                    content = content[4:]
                content = content.strip()

            parsed = json.loads(content)
        except (requests.RequestException, json.JSONDecodeError, KeyError, IndexError) as e:
            print(f"WARNING: attempt {attempt + 1} failed: {e}", file=sys.stderr)
            continue

        mapped = _map_parsed_to_styles(parsed, styles)
        for s in styles:
            if mapped.get(s):
                candidate = mapped[s]
                if _validate_caption(candidate, s):
                    result[s] = candidate
                else:
                    print(f"WARNING: caption for '{s}' failed validation, keeping existing", file=sys.stderr)

        missing = [s for s in styles if not result[s]]
        if not missing:
            return result

        print(f"WARNING: attempt {attempt + 1}: missing styles {missing}", file=sys.stderr)

    for s in styles:
        if not result[s]:
            print(f"WARNING: falling back to templated caption for style '{s}'", file=sys.stderr)
            result[s] = _fallback_caption(s, description).replace("—", ",")

    return result


def process_task(task, api_key):
    task_id = task["task_id"]
    video_url = task["video_url"]
    styles = task["styles"]
    print(f"Processing {task_id}: {video_url}", file=sys.stderr)
    description = get_video_description(video_url, api_key)
    captions = get_styled_captions(description, styles, api_key)
    return {"task_id": task_id, "captions": captions}


def main():
    api_key = get_api_key()

    if not os.path.exists(INPUT_PATH):
        print(f"ERROR: {INPUT_PATH} not found", file=sys.stderr)
        sys.exit(1)

    with open(INPUT_PATH, "r") as f:
        tasks = json.load(f)

    results = []
    had_failure = False

    for task in tasks:
        try:
            result = process_task(task, api_key)
            results.append(result)
        except Exception as e:
            print(f"ERROR processing task {task.get('task_id', '?')}: {e}", file=sys.stderr)
            had_failure = True
            results.append({
                "task_id": task.get("task_id", "unknown"),
                "captions": {s: "" for s in task.get("styles", [])},
            })

    os.makedirs(os.path.dirname(OUTPUT_PATH), exist_ok=True)
    with open(OUTPUT_PATH, "w") as f:
        json.dump(results, f, indent=2)

    print(f"Done. Wrote {len(results)} results to {OUTPUT_PATH}", file=sys.stderr)
    sys.exit(1 if had_failure else 0)


if __name__ == "__main__":
    main()
